{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Run Python App",
			"type": "shell",
			"command": "python",
			"args": [
				"main.py"
			],
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "shared"
			},
			"problemMatcher": "$python"
		},
		{
			"label": "Run Python App",
			"type": "shell",
			"command": "python"
		},
		{
			"label": "Run Tests",
			"type": "shell",
			"command": "c:/Users/harit/Endhibhey/.venv/Scripts/python.exe",
			"args": [
				"-m",
				"pytest",
				"tests/",
				"--html=reports/report.html",
				"--cov=.",
				"--cov-report=html:reports/coverage",
				"--cov-report=term"
			],
			"group": "test",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "shared"
			}
		}
	]
}